# 本地开发环境 — 通过 SSH 隧道连接 Linux MySQL
# SSH 隧道命令：ssh -N -L 33306:127.0.0.1:33306 qinminzhang@101.76.96.10

DB_HOST=localhost
DB_PORT=33306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=gwas
DB_POOL_SIZE=10

# File access mode:
# - local: read files from local/attached filesystem
# - sftp: read files from Linux server over SSH/SFTP
FILE_ACCESS_MODE=sftp

# SFTP connection (used when FILE_ACCESS_MODE=sftp)
SFTP_HOST=101.76.96.10
SFTP_PORT=22
SFTP_USERNAME=qinminzhang
# Either password or private key
SFTP_PASSWORD=
# SFTP_PRIVATE_KEY_PATH=C:\Users\10553\.ssh\id_rsa
# Or inline private key with literal \n
# SFTP_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
SFTP_PASSPHRASE=

# Remote Linux data roots for local-Windows + remote-data mode
DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/figure_all
PROGRAM_DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/run_all/outputs/program_regulator
REGULATION_DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/run_all/outputs/cNMF_regulation
GWAS_MANHATTAN_DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/run_all/outputs/gwas_manhattan
BURDEN_VOLCANO_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/run_all/outputs/burden_volcano
