# Local Windows development with Linux MySQL tunnel and remote files over SFTP.
# MySQL tunnel example:
# ssh -N -L 33306:127.0.0.1:33306 qinminzhang@101.76.96.10

NODE_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=4000
CORS_ORIGIN=*
JSON_BODY_LIMIT=1mb

DB_HOST=localhost
DB_PORT=33306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=gwas
DB_POOL_SIZE=10
DB_CONNECT_TIMEOUT_MS=10000

# File access mode:
# - local: read files from local/attached filesystem
# - sftp: read files from Linux server over SSH/SFTP
FILE_ACCESS_MODE=sftp

# SFTP connection, used only when FILE_ACCESS_MODE=sftp.
SFTP_HOST=101.76.96.10
SFTP_PORT=22
SFTP_USERNAME=qinminzhang
SFTP_PASSWORD=
# SFTP_PRIVATE_KEY_PATH=C:\Users\10553\.ssh\id_rsa
# SFTP_PRIVATE_KEY=-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----
SFTP_PASSPHRASE=
SFTP_READY_TIMEOUT=20000
SFTP_KEEPALIVE_INTERVAL=10000
SFTP_KEEPALIVE_COUNT_MAX=3

# Remote Linux data roots for local-Windows + remote-data mode.
DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/figure_all/outputs
PROGRAM_DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/run_all/outputs/figures/cnmf/tables/program_regulator
REGULATION_DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/run_all/outputs/perturbseq/cnmf_genomewide/cNMF_regulation/K562GW
GWAS_MANHATTAN_DATA_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/figure_all/outputs/gwas_manhattan/tables
BURDEN_VOLCANO_DIR=/gpfs/chencao/qinminzhang/workflow/catalog_lof/figure_all/outputs/burden_volcano/tables

# Safety limits.
MAX_PAGE_LIMIT=1000
MAX_GWAS_PAGE_LIMIT=5000
MAX_UNPAGED_GWAS_ROWS=1000000
MAX_CHR_FILTER_VALUES=30
MAX_RSID_LENGTH=100
DATA_SEARCH_INDEX_TTL_MS=120000
DATA_ALLOW_SEARCH_REFRESH=false
DATA_MAX_SEARCH_QUERY_LENGTH=120
DATA_MAX_BATCH_DOWNLOAD_ITEMS=100
DATA_MAX_DOWNLOAD_FILE_BYTES=1gb
DATA_MAX_ARCHIVE_ENTRIES=5000
DATA_MAX_ARCHIVE_BYTES=2gb
DATA_MAX_TSV_FILE_BYTES=100mb
DATA_MAX_TSV_ROWS=1000000
MANHATTAN_MAX_FILE_BYTES=1gb
MANHATTAN_MAX_ROWS=2000000
